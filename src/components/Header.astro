---
const path = Astro.url.pathname;
const links = [
  ['About','/about'],['Services','/services'],['Expertise','/expertise'],['Insights','/insights'],['Contact','/contact']
];
---
<header class="site-header" data-header>
  <div class="container nav-wrap">
    <a href="/" class="brand" aria-label="IKAI Energy Consulting home">
      <img class="brand-light" src="/images/ikai-logo-white.png" alt="IKAI Energy Consulting" />
      <img class="brand-dark" src="/images/ikai-logo-navy.png" alt="IKAI Energy Consulting" />
    </a>
    <button class="menu-button" data-menu aria-label="Open navigation" aria-expanded="false"><span></span><span></span><span></span></button>
    <nav class="nav" data-nav aria-label="Main navigation">
      {links.map(([label,href]) => <a class:list={{active:path===href || (href!=='/'&&path.startsWith(href+'/'))}} href={href}>{label}</a>)}
    </nav>
  </div>
</header>
<style>
.site-header{position:fixed;top:0;left:0;right:0;z-index:50;height:86px;transition:.3s ease;color:#fff}.site-header.scrolled,.site-header.light{background:rgba(255,255,255,.96);box-shadow:0 8px 30px rgba(3,19,38,.08);backdrop-filter:blur(18px);color:var(--navy-900)}
.nav-wrap{height:100%;display:flex;align-items:center;justify-content:space-between}.brand{width:210px;display:block}.brand img{width:100%;height:58px;object-fit:contain;object-position:left center}.brand-dark{display:none}.scrolled .brand-light,.light .brand-light{display:none}.scrolled .brand-dark,.light .brand-dark{display:block}
.nav{display:flex;align-items:center;gap:28px;font-size:.92rem;font-weight:650}.nav>a{position:relative}.nav>a::after{content:"";position:absolute;left:0;right:100%;bottom:-9px;height:2px;background:var(--gold);transition:.2s}.nav>a:hover::after,.nav>a.active::after{right:0}.menu-button{display:none;border:0;background:none;padding:8px}.menu-button span{display:block;width:26px;height:2px;background:currentColor;margin:5px}
@media(max-width:860px){.site-header{height:76px}.brand{width:170px}.menu-button{display:block;color:inherit}.nav{display:none;position:absolute;top:76px;left:0;right:0;background:#fff;color:var(--navy-900);padding:22px 24px 28px;flex-direction:column;align-items:stretch;gap:18px;box-shadow:0 20px 30px rgba(3,19,38,.1)}.nav.open{display:flex}.site-header:not(.scrolled):not(.light) .nav{background:var(--navy-950);color:#fff}}
</style>
<script>
  const header=document.querySelector('[data-header]');
  const menu=document.querySelector('[data-menu]');
  const nav=document.querySelector('[data-nav]');
  const onScroll=()=>header?.classList.toggle('scrolled',window.scrollY>20);
  onScroll(); addEventListener('scroll',onScroll,{passive:true});
  menu?.addEventListener('click',()=>{const open=nav?.classList.toggle('open');menu.setAttribute('aria-expanded',String(!!open));});
</script>
