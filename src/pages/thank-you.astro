---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Thank You | IKAI Energy Consulting" description="Your enquiry has been received by IKAI Energy Consulting.">
<section class="thanks-page">
  <div class="container thanks-wrap">
    <div class="thanks-card">
      <div class="check" aria-hidden="true">✓</div>
      <span class="eyebrow gold">Enquiry received</span>
      <h1>Thank you. IKAI has received your message.</h1>
      <p class="lead">IKAI will review your enquiry and contact you shortly. A confirmation email should arrive in your inbox; please also check your junk or spam folder.</p>
      <div class="thanks-actions">
        <a class="btn btn-primary" href="/">Return to homepage</a>
        <a class="btn btn-outline" href="/services">View IKAI services</a>
      </div>
    </div>
  </div>
</section>
</BaseLayout>
<style>.thanks-page{min-height:78vh;background:linear-gradient(135deg,var(--navy-900),var(--navy-700));display:flex;align-items:center;padding:150px 0 90px}.thanks-wrap{display:flex;justify-content:center}.thanks-card{max-width:780px;background:#fff;border-radius:24px;padding:64px;text-align:center;box-shadow:0 24px 70px rgba(0,0,0,.25)}.check{width:72px;height:72px;border-radius:50%;display:grid;place-items:center;margin:0 auto 24px;background:#eef8ef;color:#2e7d32;font-size:2.2rem;font-weight:900}.thanks-card h1{margin:18px auto 22px;max-width:650px}.thanks-card .lead{max-width:650px;margin:0 auto;color:var(--muted)}.thanks-actions{display:flex;gap:14px;justify-content:center;margin-top:34px}.thanks-card .btn-outline{color:var(--navy-900);border-color:var(--line)}@media(max-width:650px){.thanks-page{padding:120px 0 60px}.thanks-card{padding:38px 24px}.thanks-actions{flex-direction:column}.thanks-actions .btn{width:100%}}</style>
