---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Contact | IKAI Energy Consulting" description="Contact IKAI Energy Consulting in Melbourne for grid connection, power system studies and engineering advisory.">
  <section class="page-hero"><div class="container"><span class="eyebrow light">Contact</span><h1>Let’s discuss your project.</h1><p class="lead">Tell us about your technical challenge, project stage and the support you need.</p></div></section>
  <section class="section">
    <div class="container contact-grid">
      <div>
        <span class="eyebrow">Get in touch</span>
        <h2>Start a conversation with IKAI.</h2>
        <div class="contact-detail"><span>Email</span><a href="mailto:dylan.nguyen@ikaienergy.com.au">dylan.nguyen@ikaienergy.com.au</a></div>
        <div class="contact-detail"><span>Phone</span><a href="tel:+61468339333">+61 468 339 333</a></div>
        <div class="contact-detail"><span>Location</span><p>Melbourne, Australia</p></div>
      </div>
      <form class="contact-form" action="https://formsubmit.co/dylan.nguyen@ikaienergy.com.au" method="POST">
        <input type="hidden" name="_subject" value="New website enquiry — IKAI Energy Consulting" />
        <input type="hidden" name="_captcha" value="false" />
        <label>Name<input required name="name" type="text" /></label>
        <label>Email<input required name="email" type="email" /></label>
        <label>Company<input name="company" type="text" /></label>
        <label>How can we help?<textarea required name="message" rows="6"></textarea></label>
        <button class="btn btn-primary" type="submit">Send Enquiry</button>
        <p class="form-note">Your message will be sent directly to IKAI Energy Consulting.</p>
      </form>
    </div>
  </section>
</MainLayout>
<style>
.contact-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:80px}.contact-detail{padding:20px 0;border-bottom:1px solid var(--line)}.contact-detail span{display:block;color:var(--gold-500);font-size:.78rem;font-weight:900;text-transform:uppercase;letter-spacing:.14em}.contact-detail a,.contact-detail p{font-size:1.1rem;font-weight:700;margin:5px 0}.contact-form{background:var(--surface-alt);border:1px solid var(--line);border-radius:24px;padding:36px}.contact-form label{display:block;font-weight:800;margin-bottom:18px}.contact-form input,.contact-form textarea{width:100%;margin-top:7px;border:1px solid #cbd6df;border-radius:10px;padding:13px;background:white}.contact-form input:focus,.contact-form textarea:focus{outline:2px solid rgba(23,103,198,.25);border-color:#1767c6}.form-note{font-size:.82rem;color:var(--muted);margin-top:15px}
@media(max-width:850px){.contact-grid{grid-template-columns:1fr;gap:45px}}
</style>
