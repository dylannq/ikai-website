---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact | IKAI Energy Consulting" description="Contact IKAI Energy Consulting for power systems, grid connection and renewable energy engineering support.">
<section class="page-hero"><div class="container"><span class="eyebrow gold">Contact</span><h1>Let’s discuss your project.</h1><p class="lead">Tell us about the technical challenge, project stage and support you need. We will respond with a clear next step.</p></div></section>
<section class="section"><div class="container">
<div class="contact-grid"><div class="contact-details reveal"><span class="eyebrow">IKAI Energy Consulting</span><h2>Start a conversation.</h2><p class="lead">For project enquiries, partnerships or specialist technical support, contact IKAI directly or use the form.</p><div class="contact-list"><a href="mailto:dylan.nguyen@ikaienergy.com.au"><small>Email</small><b>dylan.nguyen@ikaienergy.com.au</b></a><a href="tel:+61468339333"><small>Phone</small><b>+61 468 339 333</b></a><div><small>Location</small><b>Melbourne, Australia</b></div></div></div>
<form class="contact-form card reveal" action="https://formsubmit.co/dylan.nguyen@ikaienergy.com.au" method="POST">
<input type="hidden" name="_subject" value="New enquiry from IKAI Energy website"/>
<input type="hidden" name="_template" value="table"/>
<input type="hidden" name="_next" value="https://ikaienergy.com.au/thank-you"/>
<input type="hidden" name="_autoresponse" value="Thank you for contacting IKAI Energy Consulting. We have received your enquiry and will review it shortly. We will contact you as soon as possible. Regards, IKAI Energy Consulting."/>
<input type="hidden" name="_captcha" value="true"/>
<label>Full name <span class="required">Required</span><input name="name" required autocomplete="name" placeholder="Your name"/></label>
<label>Email address <span class="required">Required</span><input type="email" name="email" required autocomplete="email" placeholder="you@example.com"/></label>
<label>Contact phone number <span class="optional">Optional</span><input type="tel" name="phone" autocomplete="tel" inputmode="tel" placeholder="e.g. +61 4xx xxx xxx"/><small class="field-help">Provide a number only when you would like us to call you.</small></label>
<label>Company <span class="optional">Optional</span><input name="company" autocomplete="organization" placeholder="Company or organisation"/></label>
<label>How can we help? <span class="required">Required</span><textarea name="message" rows="6" required placeholder="Tell us briefly about your project or enquiry"></textarea></label>
<button class="btn btn-primary" type="submit">Send enquiry ↗</button><p class="form-note">After submitting, you will be taken to a confirmation page. A confirmation email will also be sent to the email address above.</p>
</form></div></div></section>
</BaseLayout>
<style>.contact-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:70px;align-items:start}.contact-details h2{margin:20px 0}.contact-list{margin-top:45px}.contact-list a,.contact-list>div{display:block;padding:20px 0;border-top:1px solid var(--line)}.contact-list small{display:block;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);font-weight:750}.contact-list b{display:block;margin-top:5px}.contact-form{padding:38px}.contact-form label{display:block;font-weight:750;margin-bottom:22px}.optional,.required{font-size:.72rem;font-weight:700;margin-left:6px;text-transform:uppercase;letter-spacing:.06em}.optional{color:var(--muted)}.required{color:var(--blue)}.contact-form input,.contact-form textarea{width:100%;border:1px solid var(--line);border-radius:12px;padding:14px;margin-top:8px;background:#fbfcfd;font:inherit}.contact-form input:focus,.contact-form textarea:focus{outline:2px solid rgba(11,99,206,.25);border-color:var(--blue)}.field-help{display:block;margin-top:7px;color:var(--muted);font-size:.78rem;font-weight:500}.form-note{font-size:.8rem;color:var(--muted);margin-top:16px}@media(max-width:800px){.contact-grid{grid-template-columns:1fr;gap:45px}.contact-form{padding:25px}}</style>
