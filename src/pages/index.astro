---
import MainLayout from '../layouts/MainLayout.astro';
const services = [
  ['01', 'Grid Connection', 'Connection strategy, GPS, model development, studies and stakeholder engagement through the connection lifecycle.'],
  ['02', 'Power System Studies', 'RMS and EMT analysis across PSS®E, PSCAD and PowerFactory for generation, storage and network projects.'],
  ['03', "Owner's Engineer", 'Independent design review, technical assurance, project delivery and commissioning support.']
];
const expertise = ['Wind', 'Solar', 'Battery Energy Storage', 'Hybrid Projects', 'Transmission', 'Substations', 'Large Loads', 'Power Systems'];
---
<MainLayout title="IKAI Energy Consulting | Grid Connection & Power Systems" description="Independent power systems, grid connection and engineering advisory for Australia's energy transition.">
  <section class="hero">
    <div class="hero-grid-pattern"></div>
    <div class="container hero-inner">
      <div class="hero-copy">
        <span class="eyebrow light">Independent Engineering Consultancy</span>
        <h1>Engineering the<br/><span>Energy Transition.</span></h1>
        <p>Independent power systems, grid connection and engineering advisory for renewable energy, storage and network projects.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/services">Our Services</a>
          <a class="btn btn-secondary" href="/contact">Book a Consultation</a>
        </div>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <div class="orb"></div>
        <div class="grid-card">
          <div class="grid-lines"></div>
          <div class="energy-node n1"></div>
          <div class="energy-node n2"></div>
          <div class="energy-node n3"></div>
          <div class="energy-node n4"></div>
          <div class="energy-flow f1"></div>
          <div class="energy-flow f2"></div>
          <div class="energy-flow f3"></div>
          <span class="label l1">GENERATION</span>
          <span class="label l2">BESS</span>
          <span class="label l3">GRID</span>
          <span class="label l4">LOAD</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section intro">
    <div class="container intro-grid">
      <div>
        <span class="eyebrow">What We Do</span>
        <h2>Specialist advice for complex energy projects.</h2>
      </div>
      <p class="lead">IKAI helps developers, asset owners and investors navigate technical complexity from early strategy through connection, design, delivery and operations.</p>
    </div>
  </section>

  <section class="section-sm services">
    <div class="container grid grid-3">
      {services.map(([num, title, text]) => (
        <article class="card service-card">
          <span class="service-num">{num}</span>
          <h3>{title}</h3>
          <p>{text}</p>
          <a href="/services">Explore service →</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section why">
    <div class="container why-grid">
      <div class="why-panel">
        <span class="eyebrow light">Why IKAI</span>
        <h2>Independent.<br/>Practical.<br/><span>Trusted.</span></h2>
      </div>
      <div class="principles">
        <article><b>01</b><div><h3>Technical Excellence</h3><p>Rigorous analysis grounded in real project experience.</p></div></article>
        <article><b>02</b><div><h3>Practical Engineering</h3><p>Clear advice that supports decisions and project delivery.</p></div></article>
        <article><b>03</b><div><h3>Collaborative Delivery</h3><p>Effective engagement across proponents, NSPs, AEMO and delivery teams.</p></div></article>
        <article><b>04</b><div><h3>Independent Advice</h3><p>Objective technical guidance aligned with your project's interests.</p></div></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="eyebrow">Our Expertise</span>
      <h2>Across the modern energy system.</h2>
      <div class="expertise-grid">
        {expertise.map((item, i) => <a href="/expertise" class="expertise-item"><span>{String(i+1).padStart(2,'0')}</span>{item}</a>)}
      </div>
    </div>
  </section>

  <section class="section-sm">
    <div class="container cta-band">
      <div>
        <span class="eyebrow light">Start a Conversation</span>
        <h2>Let’s discuss your project.</h2>
        <p>Talk to IKAI about your grid connection, power system studies or engineering advisory needs.</p>
      </div>
      <a class="btn btn-primary" href="/contact">Book a Consultation</a>
    </div>
  </section>
</MainLayout>

<style>
.hero { min-height:760px; padding:150px 0 90px; color:white; position:relative; overflow:hidden; background:linear-gradient(120deg,#03152d 0%,#062b50 55%,#0e4d7a 100%); }
.hero-grid-pattern { position:absolute; inset:0; opacity:.18; background-image:linear-gradient(rgba(255,255,255,.08) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.08) 1px,transparent 1px); background-size:55px 55px; mask-image:linear-gradient(to right,transparent,black); }
.hero-inner { position:relative; display:grid; grid-template-columns:1.1fr .9fr; align-items:center; gap:50px; }
.eyebrow.light { color:#fff; }.eyebrow.light::before{background:#efb31c}
.hero h1 span{color:#efb31c}.hero p{font-size:1.22rem;color:rgba(255,255,255,.75);max-width:670px}
.hero-actions{display:flex;gap:14px;flex-wrap:wrap;margin-top:34px}
.hero-visual{position:relative;height:520px}.orb{position:absolute;width:440px;height:440px;border-radius:50%;right:-60px;top:30px;background:radial-gradient(circle at 35% 30%,rgba(239,179,28,.65),rgba(23,103,198,.28) 35%,rgba(3,21,45,0) 70%);filter:blur(3px)}
.grid-card{position:absolute;inset:72px 0 30px 20px;border:1px solid rgba(255,255,255,.22);border-radius:26px;background:rgba(3,21,45,.54);backdrop-filter:blur(12px);box-shadow:0 30px 70px rgba(0,0,0,.28)}
.grid-lines{position:absolute;inset:0;border-radius:inherit;background-image:linear-gradient(rgba(255,255,255,.06) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.06) 1px,transparent 1px);background-size:38px 38px}
.energy-node{position:absolute;width:22px;height:22px;border-radius:50%;border:5px solid #efb31c;box-shadow:0 0 0 8px rgba(239,179,28,.13)}
.n1{left:15%;top:25%}.n2{left:44%;top:60%}.n3{left:74%;top:27%}.n4{left:79%;top:75%}
.energy-flow{position:absolute;height:3px;transform-origin:left;background:linear-gradient(90deg,#efb31c,#3b8be0)}
.f1{left:18%;top:29%;width:43%;transform:rotate(29deg)}.f2{left:47%;top:61%;width:37%;transform:rotate(-42deg)}.f3{left:47%;top:64%;width:33%;transform:rotate(17deg)}
.label{position:absolute;font-size:.7rem;letter-spacing:.18em;color:rgba(255,255,255,.7)}.l1{left:8%;top:15%}.l2{left:36%;top:70%}.l3{left:69%;top:15%}.l4{right:5%;bottom:10%}
.intro-grid{display:grid;grid-template-columns:1fr 1fr;gap:70px;align-items:end}
.services{background:var(--surface-alt)}.service-card{position:relative;overflow:hidden}.service-num{display:block;color:#d69a00;font-weight:900;letter-spacing:.18em;margin-bottom:38px}.service-card p{color:#5d6b79}.service-card a{font-weight:800;color:#0a2d55}
.why{background:#03152d;color:white}.why-grid{display:grid;grid-template-columns:.8fr 1.2fr;gap:80px}.why-panel h2 span{color:#efb31c}.principles article{display:grid;grid-template-columns:50px 1fr;gap:22px;padding:25px 0;border-bottom:1px solid rgba(255,255,255,.15)}.principles b{color:#efb31c}.principles p{color:rgba(255,255,255,.65);margin:0}
.expertise-grid{display:grid;grid-template-columns:repeat(4,1fr);margin-top:40px;border-top:1px solid #dbe3ea;border-left:1px solid #dbe3ea}.expertise-item{min-height:145px;padding:24px;border-right:1px solid #dbe3ea;border-bottom:1px solid #dbe3ea;font-size:1.12rem;font-weight:800;display:flex;flex-direction:column;justify-content:space-between;transition:.2s}.expertise-item span{font-size:.76rem;color:#d69a00;letter-spacing:.14em}.expertise-item:hover{background:#06203f;color:white}
@media(max-width:900px){.hero{min-height:auto}.hero-inner,.intro-grid,.why-grid{grid-template-columns:1fr}.hero-visual{height:380px}.expertise-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.hero-visual{display:none}.expertise-grid{grid-template-columns:1fr}.hero{padding-top:135px}.intro-grid{gap:20px}}
</style>
