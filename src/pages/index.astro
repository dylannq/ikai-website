---
import BaseLayout from '../layouts/BaseLayout.astro';
import EnergyVisual from '../components/EnergyVisual.astro';
const services=[
['01','Grid Connection','Connection strategy, GPS negotiation, registration and stakeholder engagement from feasibility through commissioning.','/services#grid'],
['02','Power System Studies','RMS and EMT modelling across PSS®E, PSCAD and PowerFactory for robust, compliant project outcomes.','/services#studies'],
['03','Engineering Design','Electrical balance-of-plant, HV systems, substations and transmission design coordination.','/services#design'],
['04',"Owner's Engineer",'Independent technical leadership, design review, due diligence and delivery assurance.','/services#owners-engineer']
];
const sectors=[['Wind','Utility-scale wind generation and grid integration.'],['Solar','Solar farms, inverters and connection performance.'],['Battery','Grid-scale BESS and hybrid plant integration.'],['Networks','Transmission, substations and renewable energy zones.']];
---
<BaseLayout title="IKAI Energy Consulting | Power Systems & Grid Connection" description="Independent power systems, grid connection and renewable energy engineering consulting based in Melbourne, Australia.">
<section class="hero">
  <EnergyVisual/>
  <div class="container hero-inner">
    <div class="hero-copy reveal visible">
      <span class="hero-kicker">Engineering the energy transition</span>
      <h1>Independent Power Systems,<br/>Grid Connection &amp; Renewable<br/>Energy Consulting.</h1>
      <p>Power systems, grid connection and technical advisory for renewable energy and network infrastructure across Australia.</p>
      <div class="hero-actions"><a class="btn btn-primary" href="/contact">Contact <span class="arrow">↗</span></a></div>
    </div>
    <div class="hero-proof"><span>Grid connection</span><span>Power systems</span><span>Engineering design</span><span>Owner's engineer</span></div>
  </div>
</section>
<section class="intro section"><div class="container intro-grid reveal">
  <div><span class="eyebrow">What we do</span><h2>Clear engineering direction for complex energy projects.</h2></div>
  <div><p class="lead">IKAI supports developers, investors and asset owners with independent technical advice across the full project lifecycle—from early feasibility and grid strategy to commissioning and operational performance.</p><a href="/about" class="text-link">Discover IKAI <span class="arrow">→</span></a></div>
</div></section>
<section class="section section-soft"><div class="container"><div class="section-head reveal"><div><span class="eyebrow">Core services</span><h2>Technical depth.<br/>Practical delivery.</h2></div><p>Integrated engineering services that connect technical analysis with commercial and delivery priorities.</p></div>
<div class="services-grid">{services.map(([n,t,d,l])=><a href={l} class="service-card reveal"><span class="service-no">{n}</span><h3>{t}</h3><p>{d}</p><span class="card-link">Learn more <b>↗</b></span></a>)}</div></div></section>
<section class="dark-section section"><div class="container"><div class="section-head reveal"><div><span class="eyebrow gold">Why IKAI</span><h2>Independent thinking.<br/>Accountable outcomes.</h2></div><p>We combine deep technical capability with the judgement needed to make decisions, manage interfaces and move projects forward.</p></div>
<div class="why-grid"><article class="reveal"><b>01</b><h3>Technical authority</h3><p>Power system and grid connection expertise grounded in utility-scale project delivery.</p></article><article class="reveal"><b>02</b><h3>Independent advice</h3><p>Objective recommendations aligned with your project, risk profile and commercial objectives.</p></article><article class="reveal"><b>03</b><h3>End-to-end perspective</h3><p>Support from feasibility and modelling through approvals, design, construction and commissioning.</p></article></div></div></section>
<section class="section"><div class="container"><div class="section-head reveal"><div><span class="eyebrow">Sector expertise</span><h2>Built for the modern grid.</h2></div><a class="text-link" href="/expertise">View all expertise <span class="arrow">→</span></a></div>
<div class="sector-grid">{sectors.map(([t,d],i)=><a href="/expertise" class:list={['sector-card','reveal',`sector-${i+1}`]}><div class="sector-icon"><span></span></div><div><h3>{t}</h3><p>{d}</p></div><b>↗</b></a>)}</div></div></section>
<section class="insights section section-soft"><div class="container"><div class="section-head reveal"><div><span class="eyebrow">Technical insights</span><h2>Ideas that de-risk<br/>project decisions.</h2></div><a href="/insights" class="text-link">Explore all insights <span class="arrow">→</span></a></div>
<div class="grid-3"><a class="insight-card reveal" href="/insights/understanding-gps-process"><div class="insight-art art-1"></div><span>Grid connection · 7 min</span><h3>Understanding the Generator Performance Standards process in Australia</h3><b>Read insight →</b></a><a class="insight-card reveal" href="/insights/grid-connection-risks"><div class="insight-art art-2"></div><span>Project strategy · 5 min</span><h3>Five grid connection risks to address before they become programme risks</h3><b>Read insight →</b></a><a class="insight-card reveal" href="/insights/pscad-vs-psse"><div class="insight-art art-3"></div><span>Power systems · 6 min</span><h3>PSCAD versus PSS®E: selecting the right study tool for the question</h3><b>Read insight →</b></a></div></div></section>
<section class="cta-section"><div class="container cta-inner reveal"><div><span class="eyebrow gold">Start a conversation</span><h2>Need clear direction on a complex energy project?</h2></div><a href="/contact" class="btn btn-primary">Talk to IKAI <span class="arrow">↗</span></a></div></section>
</BaseLayout>
<style>
.hero{min-height:720px;background:radial-gradient(circle at 78% 16%,#164f80 0,transparent 34%),linear-gradient(125deg,#031326 12%,#061f3e 66%,#0a3157);position:relative;overflow:hidden;color:#fff}.hero::before{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(3,19,38,.98) 0%,rgba(3,19,38,.88) 42%,rgba(3,19,38,.18) 76%,rgba(3,19,38,.08) 100%);z-index:1}.hero::after{content:"";position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px);background-size:72px 72px;z-index:1}.hero-inner{position:relative;z-index:3;min-height:720px;padding-top:185px;padding-bottom:150px;display:flex;align-items:flex-start}.hero-copy{max-width:780px}.hero-kicker{text-transform:uppercase;letter-spacing:.18em;font-size:.78rem;font-weight:800;color:var(--gold)}.hero h1{color:#fff;margin-top:20px;font-size:clamp(2.8rem,5.5vw,5.5rem);line-height:1.06;max-width:900px}.hero-copy>p{font-size:1.18rem;max-width:680px;color:#e0e8ef;margin-top:26px}.hero-actions{display:flex;gap:14px;margin-top:34px}.hero-actions .btn{min-width:205px}.hero-proof{position:absolute;left:20px;right:20px;bottom:0;min-height:112px;border-top:1px solid rgba(255,255,255,.22);display:grid;grid-template-columns:repeat(4,1fr);align-items:center;color:#dce8f3;font-size:.76rem;text-transform:uppercase;letter-spacing:.14em}.hero-proof span{padding:0 26px;text-align:center}.hero-proof span+span{border-left:1px solid rgba(255,255,255,.2)}
.intro-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:90px;align-items:end}.intro h2{margin-top:22px}.text-link{display:inline-flex;gap:.6rem;font-weight:780;color:var(--navy-900);margin-top:28px;border-bottom:2px solid var(--gold);padding-bottom:4px}.services-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}.service-card{background:#fff;padding:30px;border:1px solid var(--line);border-radius:var(--radius);min-height:330px;display:flex;flex-direction:column;transition:.25s}.service-card:hover{transform:translateY(-7px);box-shadow:var(--shadow);border-color:transparent}.service-no{color:var(--gold);font-weight:850;font-size:.8rem}.service-card h3{font-size:1.45rem;margin:44px 0 16px}.service-card p{color:var(--muted);font-size:.96rem}.card-link{margin-top:auto;padding-top:24px;font-weight:750}.dark-section{background:var(--navy-900);color:#c9d6e3}.dark-section h2,.dark-section h3{color:#fff}.dark-section .section-head p{color:#b4c4d3}.gold{color:var(--gold)}.why-grid{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid rgba(255,255,255,.15)}.why-grid article{padding:42px 36px 20px 0;border-right:1px solid rgba(255,255,255,.15)}.why-grid article+article{padding-left:36px}.why-grid b{color:var(--gold)}.why-grid h3{font-size:1.5rem;margin:55px 0 16px}.why-grid p{color:#aebfd0}.sector-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}.sector-card{position:relative;min-height:240px;border-radius:var(--radius);padding:34px;color:#fff;overflow:hidden;display:flex;align-items:end;justify-content:space-between;background:var(--navy-800);transition:.25s}.sector-card:hover{transform:translateY(-5px);box-shadow:var(--shadow)}.sector-card::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 78% 20%,rgba(255,255,255,.22),transparent 33%)}.sector-card>div,.sector-card>b{position:relative}.sector-card h3{color:#fff;font-size:2rem}.sector-card p{color:#d7e3ee}.sector-2{background:#0b63ce}.sector-3{background:#366f2a}.sector-4{background:#6d4a04}.sector-card>b{font-size:1.5rem}.insight-card{background:#fff;border-radius:var(--radius);overflow:hidden;border:1px solid var(--line);padding-bottom:28px;transition:.25s}.insight-card:hover{transform:translateY(-6px);box-shadow:var(--shadow)}.insight-art{height:210px;background-color:var(--navy-900);position:relative;overflow:hidden}.insight-art::before,.insight-art::after{content:"";position:absolute;border:2px solid rgba(255,255,255,.65);border-radius:50%}.insight-art::before{width:220px;height:220px;right:-50px;top:-60px}.insight-art::after{width:130px;height:130px;right:20px;top:-15px}.art-2{background:#0b63ce}.art-3{background:#447d2c}.insight-card>span,.insight-card>h3,.insight-card>b{display:block;margin-left:26px;margin-right:26px}.insight-card>span{font-size:.72rem;text-transform:uppercase;letter-spacing:.1em;color:var(--blue);font-weight:800;margin-top:25px}.insight-card h3{font-size:1.25rem;margin-top:12px;min-height:100px}.insight-card>b{font-size:.9rem;margin-top:22px}.cta-section{background:linear-gradient(120deg,var(--navy-900),var(--navy-700));color:#fff;padding:95px 0}.cta-inner{display:flex;align-items:center;justify-content:space-between;gap:50px}.cta-inner h2{color:#fff;max-width:800px;margin-top:16px}
@media(max-width:1050px){.services-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:900px){.hero{min-height:760px}.hero-inner{min-height:760px;padding-top:155px;padding-bottom:180px}.hero::before{background:linear-gradient(90deg,rgba(3,19,38,.97),rgba(3,19,38,.72))}.hero-proof{grid-template-columns:repeat(2,1fr);min-height:142px}.hero-proof span{padding:12px}.hero-proof span:nth-child(3){border-left:0}.hero-proof span:nth-child(n+3){border-top:1px solid rgba(255,255,255,.16)}.intro-grid{grid-template-columns:1fr;gap:32px}.why-grid{grid-template-columns:1fr}.why-grid article,.why-grid article+article{padding:35px 0;border-right:0;border-bottom:1px solid rgba(255,255,255,.15)}.why-grid h3{margin-top:25px}.cta-inner{align-items:flex-start;flex-direction:column}.sector-grid{grid-template-columns:1fr}}
@media(max-width:620px){.hero{min-height:790px}.hero-inner{min-height:790px;padding-top:132px;padding-bottom:190px}.hero h1{font-size:2.75rem}.hero-actions{flex-direction:column}.hero-actions .btn{min-width:0;width:100%}.hero-proof{left:14px;right:14px;font-size:.66rem;letter-spacing:.1em}.services-grid{grid-template-columns:1fr}.service-card{min-height:280px;padding:28px}.service-card h3{margin-top:32px}.sector-card{min-height:210px}.cta-inner .btn{width:auto}}
</style>
