---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="About IKAI | IKAI Energy Consulting" description="Learn about IKAI Energy Consulting, our purpose, approach and commitment to practical engineering excellence.">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow light">About IKAI</span>
      <h1>Engineering with purpose.</h1>
      <p class="lead">Independent thinking, deep technical capability and practical delivery for Australia's evolving energy system.</p>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2">
      <div>
        <span class="eyebrow">Our Story</span>
        <h2>Purpose meets engineering.</h2>
      </div>
      <div>
        <p class="lead">IKAI is inspired by the Japanese concept of <em>ikigai</em> — a reason for being and a sense of purpose.</p>
        <p class="muted">For us, that purpose is clear: apply engineering expertise to create lasting value for clients, projects and the energy transition. We combine technical rigour with commercial awareness and practical project experience.</p>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--surface-alt)">
    <div class="container">
      <span class="eyebrow">Our Approach</span>
      <h2>Clear advice. Better decisions.</h2>
      <div class="grid grid-3">
        <article class="card"><div class="icon-tile">01</div><h3>Understand the objective</h3><p class="muted">We begin with the project outcome, decision context and key technical risks.</p></article>
        <article class="card"><div class="icon-tile">02</div><h3>Focus on what matters</h3><p class="muted">We prioritise the issues that materially affect approval, cost, schedule and performance.</p></article>
        <article class="card"><div class="icon-tile">03</div><h3>Deliver practical solutions</h3><p class="muted">Our work is designed to support action — not simply produce another report.</p></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container cta-band">
      <div><span class="eyebrow light">Work With IKAI</span><h2>Independent engineering support for your next energy project.</h2></div>
      <a class="btn btn-primary" href="/contact">Contact Us</a>
    </div>
  </section>
</MainLayout>
