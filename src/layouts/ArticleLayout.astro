---
import BaseLayout from './BaseLayout.astro';
const {title,category,readTime,description}=Astro.props;
---
<BaseLayout title={`${title} | IKAI Insights`} description={description}>
<section class="article-hero"><div class="container"><a href="/insights">← All insights</a><span>{category} · {readTime}</span><h1>{title}</h1></div></section>
<article class="section"><div class="container article-grid"><div class="prose"><slot/></div><aside><span>Discuss this topic</span><p>Need project-specific advice on grid connection or power systems?</p><a href="/contact" class="btn btn-dark">Talk to IKAI ↗</a></aside></div></article>
</BaseLayout>
<style>.article-hero{padding:160px 0 90px;background:linear-gradient(135deg,var(--navy-950),var(--navy-800));color:#fff}.article-hero a{font-weight:750;color:#fff}.article-hero span{display:block;text-transform:uppercase;letter-spacing:.12em;color:var(--blue);font-weight:800;font-size:.72rem;margin:45px 0 18px}.article-hero h1{color:#fff;font-size:clamp(2.8rem,5.5vw,5rem);max-width:1050px}.article-grid{display:grid;grid-template-columns:1fr 320px;gap:90px;align-items:start}aside{position:sticky;top:120px;border-top:3px solid var(--gold);padding-top:22px}aside span{font-weight:850}aside p{color:var(--muted);margin:12px 0 24px}@media(max-width:800px){.article-grid{grid-template-columns:1fr}aside{position:static}}</style>
